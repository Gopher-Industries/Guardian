<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prescription Management"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/fetchButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fetch Prescriptions" />

        <EditText
            android:id="@+id/prescriptionIdInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Prescription ID"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/discontinueButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Discontinue Prescription"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/deleteButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Delete Prescription"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prescription results will appear here"
            android:textSize="15sp"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>